# 复制本文件为 .env，然后填入你的 Tushare Token。
TUSHARE_TOKEN=your_tushare_token_here

# 可选配置
ETF_DATA_DIR=./data
TUSHARE_REQUEST_INTERVAL_SECONDS=0.4
TUSHARE_RETRY_TIMES=3
INDEX_POOL_FILE=./data/data_result_fixed.xlsx
INDEX_WEEKLY_START_DATE=20260501
INDEX_WEEKLY_LOOKBACK_DAYS=28

# MiniMax Search 与文本模型
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_REGION=cn
MINIMAX_SEARCH_TIMEOUT_SECONDS=45
MINIMAX_CHAT_TIMEOUT_SECONDS=60
